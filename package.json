{
  "name": "sideglass",
  "version": "0.3.0",
  "description": "A tiny always-on-top AI side window for ChatGPT, Claude, and Gemini.",
  "main": "src/main.js",
  "private": true,
  "scripts": {
    "check:syntax": "node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --check scripts/check-text.js",
    "check:text": "node scripts/check-text.js",
    "check": "npm run check:syntax && npm run check:text",
    "build:host": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-browser-host.ps1",
    "prestart": "npm run build:host",
    "start": "electron .",
    "prepack": "npm run build:host",
    "pack": "electron-builder --dir",
    "predist": "npm run build:host",
    "dist": "electron-builder --win portable",
    "dist:installer": "npm run build:host && electron-builder --win nsis"
  },
  "keywords": [
    "ai",
    "overlay",
    "electron",
    "chatgpt",
    "claude",
    "gemini"
  ],
  "author": "Hasnain Abbas",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.hasnain.sideglass",
    "productName": "SideGlass",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/SideGlassBrowserHost.exe",
        "to": "SideGlassBrowserHost.exe"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "portable"
      ],
      "artifactName": "SideGlass-${version}.${ext}"
    },
    "nsis": {
      "artifactName": "SideGlass-Setup-${version}.${ext}",
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
